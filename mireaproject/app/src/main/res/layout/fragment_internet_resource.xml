<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".ui.internetresource.InternetResourceFragment">

    <Button
        android:id="@+id/btnFetchCountry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="80dp"
        android:text="Найти" />

    <TextView
        android:id="@+id/tvCountryInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="---"
        android:textAlignment="center"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/user"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="ID пользователя: "
        android:textSize="18dp" />

    <TextView
        android:id="@+id/todoid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ID замтки: "
        android:textSize="18dp" />

    <TextView
        android:id="@+id/todo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Содержание: "
        android:textSize="18dp" />

    <TextView
        android:id="@+id/done"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сделано? -"
        android:textSize="18dp" />

</LinearLayout>